<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KHÔI PHỤC MẬT KHẨU"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nhập email bạn đã đăng ký để nhận hướng dẫn khôi phục."
        android:textAlignment="center"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/etForgotEmail"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Email của bạn"
        android:background="@android:drawable/editbox_background"
        android:paddingLeft="15dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnResetPassword"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="GỬI YÊU CẦU"/>

    <TextView
        android:id="@+id/tvBackToLoginForgot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Quay lại Đăng nhập"
        android:layout_marginTop="20dp"
        android:textColor="#2196F3"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>