<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tv_stt"
        android:layout_width="45dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="1"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="@drawable/border_table"
        android:textColor="#000000"/>

    <TextView
        android:id="@+id/tv_ma_mon_hoc"
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="1010443"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="@drawable/border_table"
        android:textColor="#000000"/>

    <TextView
        android:id="@+id/tv_ten_mon"
        android:layout_width="250dp"
        android:layout_height="match_parent"
        android:background="@drawable/border_table"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:text="Triết học Mác - Lênin"
        android:textColor="#000000"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_tin_chi"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="3.0"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="@drawable/border_table"
        android:textColor="#000000"/>

    <!-- Điểm hệ 10 -->
    <TextView
        android:id="@+id/tv_diem_he_10"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="5.9"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="@drawable/border_table"
        android:textColor="#000000"/>

    <TextView
        android:id="@+id/tv_diem_he_4"
        android:layout_width="65dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="2.00"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="@drawable/border_table"
        android:textColor="#000000"/>

    <TextView
        android:id="@+id/tv_diem_chu"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="C"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="@drawable/border_table"
        android:textColor="#000000"/>

    <LinearLayout
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:padding="8dp"
        android:background="@drawable/border_table">
        <ImageView
            android:id="@+id/iv_ket_qua"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_tichxanh"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_btn_chi_tiet"
        android:layout_width="70dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Xem"
        android:textColor="#3366CC"
        android:textStyle="bold"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="@drawable/border_table"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text=""
        android:padding="8dp"
        android:background="@drawable/border_table"/>

</LinearLayout>
