<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnBackAdmin"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_margin="5dp"
        android:background="@android:color/transparent"
        android:gravity="center"
        android:text="←"
        android:textColor="#673AB7"
        android:textSize="35sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/btnBackAdmin"
        android:layout_alignBottom="@id/btnBackAdmin"
        android:layout_toEndOf="@id/btnBackAdmin"
        android:layout_marginStart="4dp"
        android:gravity="center_vertical"
        android:text="Tài Chính Sinh Viên"
        android:textColor="#333"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btnBackAdmin"
        android:orientation="vertical"
        android:padding="16dp">

        <SearchView
            android:id="@+id/searchFinance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/custom_button"
            android:iconifiedByDefault="false"
            android:queryHint="Nhập MSSV cần kiểm tra..." />

        <!-- HKI 2025 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtTerm1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HKI 2025"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtAmount1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txtTerm1"
                    android:text="Số tiền: 25.000.000 VNĐ"
                    android:textColor="#E91E63" />

                <TextView
                    android:id="@+id/txtStatus1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Đã thanh toán"
                    android:textColor="#4CAF50"
                    android:textStyle="italic" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- HKII 2025 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtTerm2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HKII 2025"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtAmount2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txtTerm2"
                    android:text="Số tiền: 25.500.000 VNĐ"
                    android:textColor="#E91E63" />

                <TextView
                    android:id="@+id/txtStatus2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Đã Thanh Toán"
                    android:textColor="#4CAF50"
                    android:textStyle="italic" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- HKI 2026 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtTerm3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HKI 2026"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtAmount3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txtTerm3"
                    android:text="Số tiền: 26.000.000 VNĐ"
                    android:textColor="#E91E63" />

                <TextView
                    android:id="@+id/txtStatus3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Đã thanh toán"
                    android:textColor="#4CAF50"
                    android:textStyle="italic" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- HKII 2026 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtTerm4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HKII 2026"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtAmount4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txtTerm4"
                    android:text="Số tiền: 26.500.000 VNĐ"
                    android:textColor="#E91E63" />

                <TextView
                    android:id="@+id/txtStatus4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Đã thanh toán"
                    android:textColor="#4CAF50"
                    android:textStyle="italic" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewFinance"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </LinearLayout>

</RelativeLayout>