<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="20dp"
    android:orientation="vertical"
    android:background="@drawable/border_table"
    android:padding="2dp">

    <!-- Đã xóa phần Header lặp lại (Logo và tên trường) ở đây -->

    <TextView
        android:id="@+id/tv_tieu_de_bang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#003366"
        android:text="Học kỳ - Năm học"
        android:padding="8dp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="13sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TableLayout
            android:id="@+id/table_noi_dung"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#000000"
            android:padding="0.5dp">

            <TableRow>
                <TextView android:text="Mã MH" android:background="#FFD700" android:padding="8dp" android:textStyle="bold" android:gravity="center" android:textSize="11sp" android:layout_margin="0.5dp" android:textColor="#000000"/>
                <TextView android:text="Tên môn học" android:background="#FFD700" android:padding="8dp" android:textStyle="bold" android:gravity="center" android:textSize="11sp" android:layout_margin="0.5dp" android:textColor="#000000" android:minWidth="150dp"/>
                <TextView android:text="Phải đóng" android:background="#FFD700" android:padding="8dp" android:textStyle="bold" android:gravity="center" android:textSize="11sp" android:layout_margin="0.5dp" android:textColor="#000000"/>
                <TextView android:text="Đã đóng" android:background="#FFD700" android:padding="8dp" android:textStyle="bold" android:gravity="center" android:textSize="11sp" android:layout_margin="0.5dp" android:textColor="#000000"/>
                <TextView android:text="Ngày đóng" android:background="#FFD700" android:padding="8dp" android:textStyle="bold" android:gravity="center" android:textSize="11sp" android:layout_margin="0.5dp" android:textColor="#000000"/>
                <TextView android:text="Miễn giảm" android:background="#FFD700" android:padding="8dp" android:textStyle="bold" android:gravity="center" android:textSize="11sp" android:layout_margin="0.5dp" android:textColor="#000000"/>
                <TextView android:text="Còn nợ" android:background="#FFD700" android:padding="8dp" android:textStyle="bold" android:gravity="center" android:textSize="11sp" android:layout_margin="0.5dp" android:textColor="#000000"/>
            </TableRow>
        </TableLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tv_tong_cong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tổng cộng"
        android:padding="8dp"
        android:textColor="#003366"
        android:gravity="end"
        android:textStyle="bold"
        android:textSize="13sp" />
</LinearLayout>