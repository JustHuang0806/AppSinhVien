<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="24dp"
    android:orientation="vertical"
    android:background="@drawable/border_table"
    android:padding="2dp">

    <TextView
        android:id="@+id/tv_tieu_de_bang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3366CC"
        android:text="Học kỳ: ..."
        android:padding="14dp"
        android:textColor="#003366"
        android:textStyle="bold"
        android:textSize="18sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="horizontal">

        <TableLayout
            android:id="@+id/table_noi_dung"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#000000"
            android:padding="0.5dp">

            <!-- Dòng tiêu đề: Nới rộng kích thước -->
            <TableRow>
                <TextView android:text="Mã MH" android:background="#FFCC66" android:padding="14dp" android:textStyle="bold" android:gravity="center" android:textSize="15sp" android:layout_margin="0.5dp" android:textColor="#000000" android:width="80dp"/>
                <TextView android:text="Tên môn học / Nội dung" android:background="#FFCC66" android:padding="14dp" android:textStyle="bold" android:gravity="center" android:textSize="15sp" android:layout_margin="0.5dp" android:textColor="#000000" android:minWidth="250dp"/>
                <TextView android:text="Phải đóng" android:background="#FFCC66" android:padding="14dp" android:textStyle="bold" android:gravity="center" android:textSize="15sp" android:layout_margin="0.5dp" android:textColor="#000000" android:width="125dp"/>
                <TextView android:text="Đã đóng" android:background="#FFCC66" android:padding="14dp" android:textStyle="bold" android:gravity="center" android:textSize="15sp" android:layout_margin="0.5dp" android:textColor="#000000" android:width="125dp"/>
                <TextView android:text="Còn nợ" android:background="#FFCC66" android:padding="14dp" android:textStyle="bold" android:gravity="center" android:textSize="15sp" android:layout_margin="0.5dp" android:textColor="#000000" android:width="125dp"/>
            </TableRow>
        </TableLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tv_tong_cong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trạng thái: ..."
        android:padding="14dp"
        android:textColor="#003366"
        android:gravity="end"
        android:textStyle="bold"
        android:textSize="16sp"
        android:background="#F5F5F5"/>
</LinearLayout>
