<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="16dp"
    android:background="@drawable/border_table">

    <!-- Tiêu đề Học kỳ (Cố định theo chiều ngang màn hình) -->
    <TextView
        android:id="@+id/tv_semester_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3366CC"
        android:padding="10dp"
        android:text="Năm học: 2024-2025 - Học kỳ: HK01"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <!-- Cho phép lướt ngang toàn bộ bảng -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Dòng tiêu đề các cột với kích thước cố định nới rộng -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#FFCC66"
                android:orientation="horizontal">

                <TextView android:layout_width="45dp" android:layout_height="match_parent" android:text="STT" android:gravity="center" android:textStyle="bold" android:textSize="12sp" android:padding="8dp" android:background="#FFCC66" android:textColor="#000000"/>
                <TextView android:layout_width="100dp" android:layout_height="match_parent" android:text="Mã học\nphần" android:gravity="center" android:textStyle="bold" android:textSize="12sp" android:padding="8dp" android:background="#FFCC66" android:textColor="#000000"/>
                <TextView android:layout_width="250dp" android:layout_height="match_parent" android:text="Tên học phần" android:gravity="center" android:textStyle="bold" android:textSize="12sp" android:padding="8dp" android:background="#FFCC66" android:textColor="#000000"/>
                <TextView android:layout_width="60dp" android:layout_height="match_parent" android:text="Tín\nchỉ" android:gravity="center" android:textStyle="bold" android:textSize="12sp" android:padding="8dp" android:background="#FFCC66" android:textColor="#000000"/>
                <TextView android:layout_width="60dp" android:layout_height="match_parent" android:text="Điểm\nhệ 10" android:gravity="center" android:textStyle="bold" android:textSize="12sp" android:padding="8dp" android:background="#FFCC66" android:textColor="#000000"/>
                <TextView android:layout_width="65dp" android:layout_height="match_parent" android:text="Điểm\nhệ 4" android:gravity="center" android:textStyle="bold" android:textSize="12sp" android:padding="8dp" android:background="#FFCC66" android:textColor="#000000"/>
                <TextView android:layout_width="60dp" android:layout_height="match_parent" android:text="Điểm\nchữ" android:gravity="center" android:textStyle="bold" android:textSize="12sp" android:padding="8dp" android:background="#FFCC66" android:textColor="#000000"/>
                <TextView android:layout_width="60dp" android:layout_height="match_parent" android:text="Kết\nquả" android:gravity="center" android:textStyle="bold" android:textSize="12sp" android:padding="8dp" android:background="#FFCC66" android:textColor="#000000"/>
                <TextView android:layout_width="70dp" android:layout_height="match_parent" android:text="Chi\ntiết" android:gravity="center" android:textStyle="bold" android:textSize="12sp" android:padding="8dp" android:background="#FFCC66" android:textColor="#000000"/>
                <TextView android:layout_width="100dp" android:layout_height="match_parent" android:text="Ghi chú" android:gravity="center" android:textStyle="bold" android:textSize="12sp" android:padding="8dp" android:background="#FFCC66" android:textColor="#000000"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_subjects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF" />
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
